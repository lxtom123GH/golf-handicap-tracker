rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // 🔒 HELPER FUNCTIONS
    // =========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // UPDATED: Checks if the logged-in user is the assigned coach (coachUid) for the student
    function isCoachOf(studentUid) {
      let studentData = get(/databases/$(database)/documents/users/$(studentUid)).data;
      return isAuthenticated() && (
        studentData.coachUid == request.auth.uid || 
        (studentData.coaches != null && request.auth.uid in studentData.coaches) // Backward compatibility
      );
    }

    // =========================================================================
    // 👤 USERS & PROFILES
    // =========================================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());

      match /coachNotes/{noteId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isCoachOf(userId) || isAdmin());
        allow write: if isAuthenticated() && (isCoachOf(userId) || isAdmin());
      }

      match /prefs/{prefId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }

      match /practice_plans/{planId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /global_drills/{drillId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // =========================================================================
    // ⛳ ROUNDS, SHOTS & PRACTICE (MAINTENANCE UPDATES)
    // =========================================================================
    
    match /whs_rounds/{roundId} {
      // UPDATED: Restricting read access to Owner, Assigned Coach, or Admin
      allow read: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || 
        isCoachOf(resource.data.uid) || 
        isAdmin() ||
        (resource.data.visibility == "public") // Fallback for social if implemented
      );
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /shots/{shotId} {
      // UPDATED: Restricting read access to Owner, Assigned Coach, or Admin
      allow read: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || 
        isCoachOf(resource.data.uid) || 
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /practice_rounds/{roundId} {
      // Private practice data: Only the user, their coach, or an Admin
      allow read: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || 
        isCoachOf(resource.data.uid) || 
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // =========================================================================
    // 🏆 COMPETITIONS
    // =========================================================================
    
    match /competitions/{compId} {
      allow read: if isAuthenticated() && (
        resource.data.visibility == "public" || 
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.invitedUIDs || 
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /comp_rounds/{compRoundId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // =========================================================================
    // 🔑 ADMIN & SYSTEM
    // =========================================================================
    
    match /preapproved_emails/{email} {
      allow read: if isAuthenticated() || request.auth == null; 
      allow write: if isAdmin();
    }

    match /tempo/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /feed/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /users/{userId}/following/{followedId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
  }
}